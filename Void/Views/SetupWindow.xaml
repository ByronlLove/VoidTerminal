<Window x:Class="VoidTerminal.Views.SetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VoidTerminal.Views"
        mc:Ignorable="d"
        Title="Void Setup" Height="300" Width="400"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#1E1E1E" WindowStyle="None">

    <Border BorderBrush="#8A2BE2" BorderThickness="1">
        <StackPanel VerticalAlignment="Center" Margin="20">
            <TextBlock Text="INITIALISATION DU SYSTÈME" Foreground="#8A2BE2" 
                       FontSize="20" HorizontalAlignment="Center" Margin="0,0,0,20" FontWeight="Bold"/>

            <TextBlock Text="Définissez votre mot de passe maître :" Foreground="Gray" Margin="0,0,0,5"/>
            <PasswordBox x:Name="TxtPassword" Background="#2D2D30" 
                         Foreground="White" BorderThickness="0" Padding="10" Margin="0,0,0,20"/>

            <Button Content="INITIALISER" Click="BtnInit_Click"
                    Background="#8A2BE2" Foreground="White"
                    BorderThickness="0" Padding="10" Cursor="Hand"/>

            <Button Content="Quitter" Click="BtnExit_Click" Margin="0,10,0,0"
                    Background="Transparent" Foreground="Gray" BorderThickness="0"/>
        </StackPanel>
    </Border>
</Window>