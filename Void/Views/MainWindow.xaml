                                    <StackPanel Grid.Column="2" Margin="5,0,0,0">
                                        <TextBlock Text="Caractères Reset ℹ️" Foreground="#8A2BE2" FontWeight="Bold" Cursor="Hand" MouseLeftButtonUp="HelpReset_Click" ToolTip="Explications sur le reset"/>
                                        <TextBox x:Name="TxtResetChars" Margin="0,5,0,0"/>
                                        <TextBlock Text="(tout collé. Ex: .?!)" Foreground="#888" FontSize="11" Margin="0,2,0,0" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>

                            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                                <RadioButton x:Name="TabMode1" Content="Mode 1 (Décalages)" GroupName="ForgeTabs" IsChecked="True" Style="{StaticResource TabRadioStyle}" Click="TabMode_Click"/>
                                <RadioButton x:Name="TabMode2" Content="Mode 2 (Alphabet Void)" GroupName="ForgeTabs" Style="{StaticResource TabRadioStyle}" Click="TabMode_Click"/>
                            </StackPanel>

                            <Grid x:Name="PanelMode1" Grid.Row="3" Visibility="Visible">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Background="#252526" CornerRadius="5" Padding="10" Margin="0,0,0,15">
                                    <StackPanel>
                                        <TextBlock Text="Nouvelle règle de décalage:" Foreground="Orange" FontWeight="Bold" Margin="0,0,0,10"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <ComboBox x:Name="CmbRuleTarget" Grid.Column="0" Width="130" Margin="0,0,10,0" SelectedIndex="0" SelectionChanged="CmbRuleTarget_SelectionChanged">
                                                <ComboBoxItem Content="Consonnes"/>
                                                <ComboBoxItem Content="Voyelles"/>
                                                <ComboBoxItem Content="Lettre Spécifique"/>
                                            </ComboBox>
                                            <TextBox x:Name="TxtSpecificLetter" Grid.Column="1" Width="30" Margin="0,0,10,0" MaxLength="1" Visibility="Collapsed" ToolTip="Lettre (ex: E)"/>
                                            <TextBox x:Name="TxtRuleShifts" Grid.Column="2" Margin="0,0,10,0" ToolTip="Séquence de décalage (ex: 1, 2, 5)"/>
                                            <Button Grid.Column="3" Content="Ajouter" Click="BtnAddRule_Click" Style="{StaticResource ActionButtonStyle}" Padding="10,5"/>
                                        </Grid>
                                        <TextBlock Text="Format décalage: Nombres séparés par des virgules (ex: 1, 2, 5)" Foreground="Gray" FontSize="11" Margin="0,5,0,0"/>
                                    </StackPanel>
                                </Border>

                                <ListBox x:Name="ListRules" Grid.Row="1" 
         Background="#161616" BorderThickness="1" BorderBrush="#3E3E42" 
         Foreground="White" FontFamily="Consolas" FontSize="14" 
         ScrollViewer.CanContentScroll="True" HorizontalContentAlignment="Stretch"
         AllowDrop="True"
         PreviewMouseLeftButtonDown="ListRules_PreviewMouseLeftButtonDown"
         PreviewMouseMove="ListRules_MouseMove"
         Drop="ListRules_Drop"
         DragEnter="ListRules_DragEnter"
         PreviewDragOver="ListRules_PreviewDragOver"
         GiveFeedback="ListRules_GiveFeedback">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="5" Background="Transparent" Cursor="SizeAll">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Text="{Binding DisplayText}" VerticalAlignment="Center" Foreground="#00FFCC"/>

                                                <Button Grid.Column="1" Content="✕" Foreground="#FF5555" Background="Transparent" 
                        BorderThickness="0" Cursor="Hand" FontWeight="Bold" 
                        Click="BtnDeleteRule_Click" Tag="{Binding Rule}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>

                            <Grid x:Name="PanelMode2" Grid.Row="3" Visibility="Collapsed">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Définissez les symboles pour chaque lettre :" Foreground="Orange" FontWeight="Bold" Margin="0,0,0,10"/>

                                <ListBox x:Name="ListVoidAlphabet" Grid.Row="1" Background="#161616" BorderThickness="1" BorderBrush="#3E3E42" Foreground="White" FontFamily="Consolas" FontSize="16" ScrollViewer.CanContentScroll="True">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="5,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="30"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="200"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Key}" VerticalAlignment="Center" Foreground="Orange" FontWeight="Bold"/>
                                                <TextBlock Grid.Column="1" Text="=" VerticalAlignment="Center" Foreground="Gray" Margin="10,0"/>
                                                <TextBox Grid.Column="2" Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Padding="5"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>

                            <Grid Grid.Row="4" Margin="0,20,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0" Content="📥 Import" Click="BtnImportConfig_Click" Background="#252526" Foreground="White" Width="100" Height="35" Margin="0,0,10,0" Style="{StaticResource StandardButtonStyle}"/>
                                <Button Grid.Column="1" Content="📤 Export" Click="BtnExportConfig_Click" Background="#252526" Foreground="White" Width="100" Height="35" Style="{StaticResource StandardButtonStyle}"/>

                                <Button Grid.Column="3" Content="Sauvegarder Configuration" Click="BtnSaveForge_Click" Background="#8A2BE2" Foreground="White" Width="200" Height="35" Margin="0,0,10,0" Style="{StaticResource ActionButtonStyle}"/>
                                <Button Grid.Column="4" Content="Annuler" Click="BtnCancelForge_Click" Background="#444" Foreground="White" Width="100" Height="35" Style="{StaticResource StandardButtonStyle}"/>
                            </Grid>
                        </Grid>
                    </Border>
                    <Border x:Name="LaserBorderForge" BorderThickness="2" CornerRadius="10" IsHitTestVisible="False" Opacity="0">
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="Transparent" Offset="0.5"/>
                                <GradientStop Color="#8A2BE2" Offset="0.5"/>
                                <GradientStop Color="#8A2BE2" Offset="0.5"/>
                                <GradientStop Color="Transparent" Offset="0.5"/>
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                    </Border>
                </Grid>
            </Grid>

            <Grid x:Name="CustomAlertOverlay" Grid.RowSpan="2" Background="#CC000000" Visibility="Collapsed" MouseLeftButtonUp="OnOverlayClick" Panel.ZIndex="100">
                <Grid Width="450" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Border Background="#1E1E1E" CornerRadius="10" Style="{StaticResource PopUpBorderStyle}">
                        <StackPanel Margin="20" VerticalAlignment="Center">
                            <TextBlock x:Name="LblAlertTitle" Text="Information" Foreground="#8A2BE2" FontWeight="Bold" FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                            <TextBlock x:Name="LblAlertMessage" Text="Message ici" Foreground="White" FontSize="14" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" Margin="0,0,0,25"/>
                            <Button x:Name="BtnAlertOk" Content="OK" Click="BtnCloseAlert_Click" Background="#8A2BE2" Foreground="White" Width="100" Height="35" Style="{StaticResource ActionButtonStyle}"/>
                        </StackPanel>
                    </Border>
                    <Border x:Name="LaserBorderAlert" BorderThickness="2" CornerRadius="10" IsHitTestVisible="False" Opacity="0">
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="Transparent" Offset="0.5"/>
                                <GradientStop Color="#8A2BE2" Offset="0.5"/>
                                <GradientStop Color="#8A2BE2" Offset="0.5"/>
                                <GradientStop Color="Transparent" Offset="0.5"/>
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                    </Border>
                </Grid>
            </Grid>

        </Grid>
    </Border>
</Window>